# Discord Bot Token — create at https://discord.com/developers/applications → Your App → Bot → Reset Token
DISCORD_TOKEN=your_bot_token_here

# Optional: text channel IDs where Luna auto-joins voice and speaks when she replies. Leave empty to only use TTS when you !join her to VC.
# DISCORD_TTS_CHANNEL_IDS=123456789012345678

# Ollama (Luna's brain). Install: https://ollama.ai — then: ollama pull qwen2.5-coder:7b-instruct
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5-coder:7b-instruct
# Optional: small/fast model for command parsing and summarization (saves latency). If unset, main model is used.
# OLLAMA_MODEL_SMALL=phi3:mini

# Suno only: when !play Suno stream fails, download here and play from file. YouTube always uses temp. Default: D:\Downloads\youtube shorts quotes chris\youtube quotes excel list_files
# LUNA_MUSIC_DOWNLOAD_DIR=D:\Downloads\youtube shorts quotes chris\youtube quotes excel list_files

# Scheduled X and Facebook posts (2 times per day). Default 10:00 and 18:00 Cyprus time (system local time). Comma-separated 24h.
# SCHEDULE_SHARE_TIMES=10:00,18:00
